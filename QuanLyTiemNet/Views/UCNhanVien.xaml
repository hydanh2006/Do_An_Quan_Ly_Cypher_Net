<UserControl x:Class="QuanLyTiemNet.Views.UCNhanVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="DANH SÁCH NHÂN SỰ" FontSize="24" FontWeight="Bold" Foreground="#3b82f6"/>
                <TextBlock Text="Quản lý thông tin, phân ca và lương nhân viên tiệm Net." Foreground="#94a3b8" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#1E293B" CornerRadius="8" Margin="0,0,15,0" Width="280" Height="40">
                <Grid>
                    <TextBlock Text="🔍 Tìm kiếm theo tên nhân viên..." Foreground="#64748B" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text.Length, ElementName=txtTimKiem}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBox x:Name="txtTimKiem" Background="Transparent" Foreground="White" BorderThickness="0" 
                     VerticalContentAlignment="Center" Padding="10,0,10,0" FontSize="14"
                     Text="{Binding TuKhoaTimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <Button Grid.Column="2" Height="40" Padding="15,0" Background="#3b82f6" BorderThickness="0" 
            Visibility="{Binding HienThiAdmin}"
            Command="{Binding AddNhanVienCommand}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,2"/>
                    <TextBlock Text="Thêm nhân sự mới" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding DanhSachNhanVien}" AutoGenerateColumns="False" 
                  Background="Transparent" BorderThickness="0" CanUserAddRows="False" RowHeaderWidth="0"
                  GridLinesVisibility="None" SelectionMode="Single">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,15"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#1F2937"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#1F2937"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>

                <DataGridTemplateColumn Header="HỌ VÀ TÊN" Width="2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HoTen}" Foreground="#3B82F6" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="CA LÀM" Binding="{Binding CaLamViec}" Width="1.5*"/>

                <DataGridTextColumn Header="CHỨC VỤ" Binding="{Binding ChucVu}" Width="1.5*"/>

                <DataGridTemplateColumn Header="LƯƠNG CƠ BẢN" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding LuongCoBanString}" Foreground="#10B981" FontWeight="Medium"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="TRẠNG THÁI" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Background="{Binding StatusBg}">
                                <TextBlock Text="{Binding TrangThaiText}" Foreground="{Binding StatusFg}" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="THAO TÁC" Width="120" Visibility="{Binding DataContext.HienThiAdmin, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Sửa" Background="Transparent" Foreground="#10B981" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"
                                        Command="{Binding DataContext.SuaNhanVienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                <Button Content="Xóa" Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.XoaNhanVienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</UserControl>

