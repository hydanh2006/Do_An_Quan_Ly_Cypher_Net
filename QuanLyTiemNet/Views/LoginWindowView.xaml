<Window x:Class="QuanLyTiemNet.Views.LoginWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Đăng nhập hệ thống - Cyber Net" Height="550" Width="420"
WindowStyle="None" AllowsTransparency="True" Background="Transparent"
WindowStartupLocation="CenterScreen">
    <Border Background="#0f172a" BorderBrush="#1e293b" BorderThickness="2" CornerRadius="20">
        <Grid Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,30">
                <Border Width="58" Height="56" Background="#2563eb" CornerRadius="12" HorizontalAlignment="Center">
                    <TextBlock Text="DTK" Foreground="White" FontWeight="Black" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="CYBER NET" Foreground="White" FontWeight="Black" FontSize="20" Margin="0,15,0,2" HorizontalAlignment="Center"/>
                <TextBlock Text="Hệ Thống Quản Lý Tiệm Net" Foreground="#64748b" FontSize="12" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Tên đăng nhập" Foreground="#94a3b8" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                <TextBox x:Name="txtUsername" Background="#090d16" Foreground="White" BorderBrush="#334155" BorderThickness="1.5" 
                         Padding="12" FontSize="14" CaretBrush="White" SelectionBrush="#2563eb" Margin="0,0,0,20">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Mật khẩu bảo mật" Foreground="#94a3b8" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                <PasswordBox x:Name="txtPassword" Background="#090d16" Foreground="White" BorderBrush="#334155" BorderThickness="1.5" 
                             Padding="12" FontSize="14" CaretBrush="White" Margin="0,0,0,10">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,20,0,10">
                <Button x:Name="btnLogin" Content="Đăng nhập vào hệ thống" Click="BtnLogin_Click"
                        Background="#2563eb" Foreground="White" FontSize="14" FontWeight="Bold" Padding="14" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnExit" Content="Thoát phần mềm" Click="BtnExit_Click"
                        Background="Transparent" Foreground="#64748b" FontSize="13" Margin="0,12,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
