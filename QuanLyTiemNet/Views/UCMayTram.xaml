<UserControl x:Class="QuanLyTiemNet.Views.UCMayTram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:QuanLyTiemNet.Converters" 
             Background="Transparent">

    <UserControl.Resources>
        <conv:TrangThaiToVisibilityConverter x:Key="TrangThaiToVis"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="229*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="20,10,20,20">

            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="QUẢN LÝ MÁY TRẠM" FontSize="24" FontWeight="ExtraBold" Foreground="#3b82f6" Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Quản lý trạng thái, tính tiền và theo dõi hệ thống.  |  " Foreground="#94a3b8" FontSize="14"/>

                    <TextBlock Text="Tổng: " Foreground="#94a3b8" FontSize="14"/>
                    <TextBlock Text="{Binding TongSoMay}" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>

                    <TextBlock Text="Đang chơi: " Foreground="#94a3b8" FontSize="14"/>
                    <TextBlock Text="{Binding MayDangDung}" Foreground="#ef4444" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>

                    <TextBlock Text="Bảo trì: " Foreground="#94a3b8" FontSize="14"/>
                    <TextBlock Text="{Binding MayBaoTri}" Foreground="#f59e0b" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding HienThiAdmin}">
                <TextBlock Text="Loại máy: " VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
                <ComboBox Width="100" SelectedValuePath="Content" SelectedValue="{Binding LoaiMayDuocChon}" Margin="5,0,10,0">
                    <ComboBoxItem Content="Thường"/>
                    <ComboBoxItem Content="VIP"/>
                </ComboBox>

                <Button Content="+ Thêm máy mới" Command="{Binding ThemMayCommand}" 
                        Background="{StaticResource AccentBlue}" Foreground="White" Padding="10,5"/>
            </StackPanel>

        </Grid>

        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2">
            <ItemsControl ItemsSource="{Binding DS_May}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="140" Margin="10" CornerRadius="8" Background="#111827" BorderThickness="2">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                          Command="{Binding DataContext.MoMenuKhoiDongCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                          CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#1f2937"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                            <Setter Property="BorderBrush" Value="LightGreen"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                            <Setter Property="BorderBrush" Value="#f59e0b"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid Background="Transparent">
                                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Background="Transparent" Foreground="#ef4444" BorderThickness="0" 
                                    Margin="0,5,5,0" FontWeight="Bold" FontSize="14" Cursor="Hand" ToolTip="Xóa máy này"
                                    Visibility="{Binding DataContext.HienThiAdmin, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Command="{Binding DataContext.XoaMayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>      

                                <StackPanel VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock Text="{Binding TenMay}" FontWeight="Bold" Foreground="White" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                                    <TextBlock Text="Sẵn sàng" Foreground="#4b5563" HorizontalAlignment="Center"
                           Visibility="{Binding TrangThai, Converter={StaticResource TrangThaiToVis}, ConverterParameter='1'}"/>

                                    <StackPanel Visibility="{Binding TrangThai, Converter={StaticResource TrangThaiToVis}, ConverterParameter='2'}">
                                        <TextBlock Text="{Binding TenKhachHang}" Foreground="#94a3b8" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding ThoiGianHienThi}" Foreground="#ef4444" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Text="Đang bảo trì" Foreground="#f59e0b" HorizontalAlignment="Center"
                           Visibility="{Binding TrangThai, Converter={StaticResource TrangThaiToVis}, ConverterParameter='3'}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
