<Window x:Class="QuanLyTiemNet.Views.DialogDKHoiVien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng Ký Hội Viên" Height="360" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="#0d1527" CornerRadius="16" BorderBrush="#1e293b" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Đăng Ký Hội Viên" FontSize="20" FontWeight="Black" Foreground="#3b82f6"/>
                <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                        Foreground="#475569" FontSize="16" Cursor="Hand" Click="BtnHuy_Click" />
            </Grid>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Tài khoản (Username)" Foreground="#94a3b8" FontSize="13" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NewTaiKhoan.TenDangNhap, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#050811" Foreground="White" BorderBrush="#1e293b" BorderThickness="1.5" 
                         Padding="10" Height="40" Margin="0,0,0,14" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Tên hiển thị" Foreground="#94a3b8" FontSize="13" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NewTaiKhoan.HoTen, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#050811" Foreground="White" BorderBrush="#1e293b" BorderThickness="1.5" 
                         Padding="10" Height="40" Margin="0,0,0,14" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Mật khẩu" Foreground="#94a3b8" FontSize="13" Margin="0,0,0,6"/>
                <TextBox Text="{Binding NewTaiKhoan.MatKhau, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#050811" Foreground="White" BorderBrush="#1e293b" BorderThickness="1.5" 
                         Padding="10" Height="40" Margin="0,0,0,10" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Hủy" Width="70" Height="36" Click="BtnHuy_Click"
                        Background="#1e293b" Foreground="#94a3b8" BorderThickness="0" Margin="0,0,12,0" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Lưu" Width="70" Height="36" Click="BtnLuu_Click"
                        Background="#2563eb" Foreground="White" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>