<UserControl x:Class="QuanLyTiemNet.Views.UCHoiVien"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="QUẢN LÝ HỘI VIÊN" FontSize="24" FontWeight="Bold" Foreground="#3b82f6"/>
                <TextBlock Text="Quản lý tài khoản, thông tin khách hàng và nạp tiền giờ chơi." Foreground="#94a3b8" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Height="40" Padding="15,0" Background="#3b82f6" BorderThickness="0" 
                    Command="{Binding AddHoiVienCommand}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,2"/>
                    <TextBlock Text="Tạo tài khoản mới" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding DanhSachHoiVien}" AutoGenerateColumns="False" 
                  Background="Transparent" BorderThickness="0" CanUserAddRows="False" RowHeaderWidth="0"
                  GridLinesVisibility="None" SelectionMode="Single">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,15"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#1F2937"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#1F2937"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>

                <DataGridTemplateColumn Header="TÊN ĐĂNG NHẬP" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TenDangNhap}" Foreground="#3B82F6" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="HỌ VÀ TÊN" Binding="{Binding HoTen}" Width="2*"/>

                <DataGridTemplateColumn Header="SỐ DƯ (VNĐ)" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SoDu, StringFormat=\{0:N0\} đ}" Foreground="#10B981" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="THAO TÁC" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Nạp tiền" Background="#F59E0B" Foreground="White" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Padding="8,4"
                                        Command="{Binding DataContext.NapTienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Content="Sửa" Background="Transparent" Foreground="#10B981" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"
                                        Command="{Binding DataContext.SuaHoiVienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>

                                <Button Content="Xóa" Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.XoaHoiVienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>