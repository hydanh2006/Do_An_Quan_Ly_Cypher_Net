<UserControl x:Class="QuanLyTiemNet.Views.UCBaoCao"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <TextBlock Text="TRUNG TÂM BÁO CÁO" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,20"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="TỔNG DOANH THU" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="0 ₫" Foreground="#10b981" FontSize="32" FontWeight="Black" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="TIỀN GIỜ MÁY" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="0 ₫" Foreground="#38bdf8" FontSize="32" FontWeight="Black" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource BgCard}" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="DOANH THU CĂNG TIN" Foreground="{StaticResource TextMuted}" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="0 ₫" Foreground="#f59e0b" FontSize="32" FontWeight="Black" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
