<Window x:Class="QuanLyTiemNet.Views.DialogInHoaDonTong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="In Hóa Đơn Tổng Ngày" Height="550" Width="420"
        WindowStartupLocation="CenterScreen" Background="#F1F5F9" WindowStyle="ToolWindow">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border x:Name="KhuVucIn" Grid.Row="0" Background="White" Padding="20" BorderBrush="#CBD5E1" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="CYBER NETPRO" FontSize="22" FontWeight="Black" HorizontalAlignment="Center"/>
                    <TextBlock Text="Đ/C: Lê Trọng Tấn, P.Tây Thạnh, TP. HCM" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="Gray"/>
                    <TextBlock Text="------------------------------------------------------------" HorizontalAlignment="Center" Margin="0,10" Foreground="Gray"/>

                    <TextBlock Text="HÓA ĐƠN TỔNG TRONG NGÀY" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtTenKhach" Text="Tài khoản: [Tên khách]" FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtNgayIn" Text="Ngày áp dụng: [Ngày hôm nay]" FontSize="12" Foreground="DimGray" Margin="0,2,0,10"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="dgChiTietGiaoDich" AutoGenerateColumns="False" 
                          Background="Transparent" BorderThickness="0" CanUserAddRows="False" RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E2E8F0" IsReadOnly="True">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="0,5"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="Black"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0,5"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thời gian" Binding="{Binding ThoiGianNapString}" Width="110"/>
                        <DataGridTextColumn Header="Loại giao dịch / Sản phẩm" Binding="{Binding SoTienNapString}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="3" Margin="0,15,0,0">
                    <TextBlock Text="------------------------------------------------------------" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="Gray"/>

                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="TỔNG TIỀN THANH TOÁN:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtTongTien" Text="0 VNĐ" FontSize="18" FontWeight="Black" HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="Cảm ơn quý khách và hẹn gặp lại!" FontSize="12" FontStyle="Italic" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Hủy bỏ" Width="90" Height="35" Margin="0,0,10,0" Background="#94A3B8" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnHuy_Click"/>
            <Button Content="🖨️ XÁC NHẬN IN HÓA ĐƠN TỔNG" Width="240" Height="35" Background="#8B5CF6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnIn_Click"/>
        </StackPanel>
    </Grid>
</Window>