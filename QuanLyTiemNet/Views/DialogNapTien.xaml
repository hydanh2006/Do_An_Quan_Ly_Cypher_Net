<Window x:Class="QuanLyTiemNet.Views.DialogNapTien"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nạp Tiền" Height="380" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border Background="#0f172a" CornerRadius="12" BorderBrush="#F59E0B" BorderThickness="2" MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid Margin="20">
            <StackPanel>
                <TextBlock Text="NẠP TIỀN GIỜ CHƠI" FontSize="18" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock x:Name="txtTenKhach" Text="Đang nạp cho: [Tên khách]" Foreground="White" Margin="0,0,0,10"/>

                <TextBlock Text="Nhập số tiền nạp thủ công (VNĐ):" Foreground="#94a3b8" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSoTienNap" Height="40" Background="#1e293b" Foreground="White" FontSize="16" FontWeight="Bold" Padding="10,0" VerticalContentAlignment="Center" BorderThickness="0" Margin="0,0,0,15"/>

                <TextBlock Text="Hoặc chọn Gói Combo nạp nhanh:" Foreground="#94a3b8" Margin="0,0,0,8"/>
                <UniformGrid Columns="2" Rows="2" Margin="0,0,0,20">
                    <Button Content="Combo 20K" Tag="20000" Height="35" Margin="0,0,10,10" Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnCombo_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Combo 50K" Tag="50000" Height="35" Margin="0,0,0,10" Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnCombo_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Combo 100K" Tag="100000" Height="35" Margin="0,0,10,0" Background="#8B5CF6" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnCombo_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Combo Xuyên Đêm" Tag="80000" Height="35" Margin="0,0,0,0" Background="#EC4899" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnCombo_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </UniformGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Width="80" Height="35" Background="#334155" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand" Click="BtnHuy_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="Xác nhận Nạp" Width="120" Height="35" Background="#F59E0B" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnNap_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>