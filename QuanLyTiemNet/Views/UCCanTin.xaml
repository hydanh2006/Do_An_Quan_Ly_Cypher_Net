<UserControl x:Class="QuanLyTiemNet.Views.UCCanTin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="CĂNG TIN &amp; DỊCH VỤ" FontSize="24" FontWeight="Bold" Foreground="#F59E0B"/>
                <TextBlock Text="Quản lý thực đơn đồ ăn, thức uống và thẻ game." Foreground="#94a3b8" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Height="40" Padding="15,0" Background="#8B5CF6" BorderThickness="0" Margin="0,0,15,0" 
                        Command="{Binding MoPhongGoiMonNgauNhienCommand}" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎲" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Text="Mô phỏng gọi món" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <ComboBox Width="160" Height="40" Margin="0,0,15,0" Padding="10,0" VerticalContentAlignment="Center"
                          SelectedValue="{Binding BoLocPhanLoai}" SelectedValuePath="Content"
                          Background="#1E293B" Foreground="Black" BorderThickness="0" FontSize="14">
                    <ComboBoxItem Content="Tất cả"/>
                    <ComboBoxItem Content="Đồ ăn"/>
                    <ComboBoxItem Content="Nước uống"/>
                    <ComboBoxItem Content="Thẻ game"/>
                </ComboBox>

                <Button Height="40" Padding="15,0" Background="#F59E0B" BorderThickness="0" 
                        Visibility="{Binding HienThiAdmin}" Command="{Binding AddDichVuCommand}" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,2"/>
                        <TextBlock Text="Thêm món mới" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding DanhSachDichVu}" AutoGenerateColumns="False" 
                  Background="Transparent" BorderThickness="0" CanUserAddRows="False" RowHeaderWidth="0"
                  GridLinesVisibility="None" SelectionMode="Single">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="12,15"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#1F2937"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#1F2937"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="60"/>

                <DataGridTemplateColumn Header="TÊN MÓN / DỊCH VỤ" Width="2.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TenDichVu}" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="PHÂN LOẠI" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Background="{Binding PhanLoaiBg}">
                                <TextBlock Text="{Binding PhanLoai}" Foreground="{Binding PhanLoaiFg}" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="ĐƠN GIÁ" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DonGiaString}" Foreground="#10B981" FontWeight="Bold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="TỒN KHO" Binding="{Binding TonKho}" Width="1*"/>
                <DataGridTemplateColumn Header="THAO TÁC" Width="200" Visibility="{Binding DataContext.HienThiAdmin, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Mô phỏng gọi" Background="#8B5CF6" Foreground="White" BorderThickness="0" Margin="0,0,15,0" Cursor="Hand" Padding="8,4"
                                Command="{Binding DataContext.MoPhongGoiMonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Content="Sửa" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"
                                Command="{Binding DataContext.SuaDichVuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                <Button Content="Xóa" Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand"
                                Command="{Binding DataContext.XoaDichVuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTemplateColumn Header="THAO TÁC" Width="120" Visibility="{Binding DataContext.HienThiAdmin, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Sửa" Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"
                                        Command="{Binding DataContext.SuaDichVuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                <Button Content="Xóa" Background="Transparent" Foreground="#EF4444" BorderThickness="0" Cursor="Hand"
                                        Command="{Binding DataContext.XoaDichVuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="0,20,20,0" Padding="20,12" Background="#10B981" CornerRadius="8" 
                Visibility="{Binding HienThiThongBao}" Panel.ZIndex="99">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.4" Direction="270" Color="Black"/>
            </Border.Effect>
            <TextBlock Text="{Binding ThongBaoText}" Foreground="White" FontWeight="Bold" FontSize="15"/>
        </Border>

    </Grid>
</UserControl>