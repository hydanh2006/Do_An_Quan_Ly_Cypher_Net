<UserControl x:Class="QuanLyTiemNet.Views.UCCanTin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BgCard}" CornerRadius="12" Margin="0,0,15,0" Padding="20">
            <StackPanel>
                <TextBlock Text="THỰC ĐƠN DỊCH VỤ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,15"/>
                <TextBlock Text="Khu vực hiển thị các món ăn..." Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BgCard}" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="CHI TIẾT ĐƠN VÀO MÁY" FontSize="20" FontWeight="Bold" Foreground="#10b981" Margin="0,0,0,15"/>
                <TextBlock Text="Vui lòng chọn máy trạm và gọi món bên trái." Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
