<UserControl x:Class="QuanLyTiemNet.Views.UCBaoCaoDoanhThu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="BÁO CÁO DOANH THU" FontSize="24" FontWeight="Bold" Foreground="#EC4899"/>
                <TextBlock Text="Thống kê dòng tiền nạp và biểu đồ doanh số quán Net." Foreground="#94a3b8" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <Button Grid.Column="1" Height="40" Padding="15,0" Background="#EC4899" BorderThickness="0" 
                    Command="{Binding RefreshCommand}" Cursor="Hand" VerticalAlignment="Center">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄" FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Tải lại dữ liệu" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E293B" CornerRadius="12" Padding="20" BorderBrush="#10B981" BorderThickness="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="DOANH THU HÔM NAY" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding DoanhThuHomNay}" Foreground="#10B981" FontSize="26" FontWeight="Black"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1E293B" CornerRadius="12" Padding="20" BorderBrush="#3B82F6" BorderThickness="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="DOANH THU THÁNG NÀY" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding DoanhThuThangNay}" Foreground="#3B82F6" FontSize="26" FontWeight="Black"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="#1E293B" CornerRadius="12" Padding="20" BorderBrush="#A855F7" BorderThickness="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="TỔNG TÀI SẢN NẠP" Foreground="#94A3B8" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding TongDoanhThu}" Foreground="#A855F7" FontSize="26" FontWeight="Black"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#0F172A" CornerRadius="16" Padding="20" BorderBrush="#1E293B" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Biểu đồ doanh thu 7 ngày qua" Foreground="#E2E8F0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding DuLieuBieuDo}" Margin="20,0,20,10">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Bottom" Margin="10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding DoanhThuString}" Foreground="#3B82F6" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>

                                <Border Grid.Row="1" Background="#3B82F6" CornerRadius="4,4,0,0" Width="40" Height="{Binding ChieuCaoCot}" VerticalAlignment="Bottom" ToolTip="{Binding DoanhThuString}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#60A5FA"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <TextBlock Grid.Row="2" Text="{Binding Ngay}" Foreground="#94A3B8" FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>